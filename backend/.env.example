# --- App ---
APP_NAME=360-Dash
DEBUG=true
DATABASE_URL=sqlite:///./360dash.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/360dash   # production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# --- Admin seed (used on first startup) ---
ADMIN_EMAIL=admin@360eventsaruba.com
ADMIN_PASSWORD=change-me-on-first-login

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# In Twilio sandbox the FROM is the sandbox number above. For production, replace with your approved sender.
