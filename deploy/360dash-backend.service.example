[Unit]
Description=360-Dash FastAPI backend
After=network.target postgresql.service

[Service]
User=dash360
Group=dash360
WorkingDirectory=/opt/360dash/repo/backend
EnvironmentFile=/opt/360dash/.env
ExecStart=/opt/360dash/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
