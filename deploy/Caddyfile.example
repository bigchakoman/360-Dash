# Reference Caddyfile snippet for 360-Dash.
# install.sh appends a working version of this to /etc/caddy/Caddyfile automatically.
# Replace dash.360eventsaruba.com with your real hostname.

dash.360eventsaruba.com {
    encode zstd gzip

    # API → uvicorn on 127.0.0.1:8000 (the leading /api is stripped before forwarding)
    handle_path /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    # Static frontend (Vite build output) with SPA fallback
    handle {
        root * /opt/360dash/repo/frontend/dist
        try_files {path} /index.html
        file_server
    }
}
